prefix=/opt/homebrew/Cellar/whisper-cpp/1.9.1
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

Name: whisper
Description: Port of OpenAI's Whisper model in C/C++
Version: 1.9.1
Libs: -L${libdir} -L/opt/homebrew/lib -lggml -lggml-base -lwhisper
Cflags: -I${includedir} -I/opt/homebrew/include
